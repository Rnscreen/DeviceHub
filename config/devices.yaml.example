# 基于 devices.yaml 模板，为 TC_mock 创建设备实例
devices:
  TC_mock:
    id: "TC_mock" # 同上, 需要与dict的key一致
    name: "Temperature Controller Mock" # 一些基本信息, 这里可以自定义设备名称
    type: "temperature_controller" # 设备类型
    vendor: "Rnscreen" # 设备厂商
    model: "TC_mock"            # 对应协议文件名 (TC_mock_v1.0.yaml)
    version: "v1.0"             # 对应协议版本
    enabled: true               # 是否启用
    connection:                 # 连接配置
      host: "127.0.0.1"         # 设备IP地址
      port: 9001                # 设备端口号
      timeout: 0.2              # 连接超时时间
    enabled_channels:           # 启用 A, B 两个通道
      CH: ["A", "B"]            # 在通道组 CH 中启用 A, B 两个通道
    poll:                       # 轮询配置
      poll_interval: 0.6        # 轮询基础频率
      poll_slow: 5              # 每几次更新一次慢监控
      poll_status: 10          # 每几次轮询更新一次status
      monitoring: ["temperature", "power", "mode"] # 推送到websocket的监控的通道
      saver: ["temperature", "power"] # 保存到数据库的通道
    tags: # 设备标签
      location: "Test Bench"
    description: "A mock temperature controller with PID simulation for channels A and B." # 设备描述

  PUMP_mock:
    id: "PUMP_mock"
    name: "Vacuum Pump Mock"
    type: "vacuum_pump"
    vendor: "MockVendor"
    model: "PUMP_mock"
    version: "v1.0"
    enabled: true
    connection:
      host: "127.0.0.1"
      port: 9002
      timeout: 0.2
    enabled_channels:
      CH: []
    poll:
      poll_interval: 0.6
      poll_slow: 5
      poll_status: 10
      monitoring: ["pressure", "power", "pump_status"]
      saver: ["pressure"]
    tags:
      location: "Chamber #1"
    description: "A mock vacuum pump simulator with pressure dynamics."

# 设备分组
groups: 
  chamber:  # 组名id
    name: "机柜" # 组名
    devices: ["test1"] # 组中的设备id
    description: "位于机柜中的设备" # 组描述